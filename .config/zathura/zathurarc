include catppuccin-mocha

set window-title-basename "true"
set selection-clipboard "clipboard"
map b toggle_statusbar

# set font "Roboto 11"


# Startup options
set adjust-open width
set recolor true

map <C-l> feedkeys ":blist <Tab>"

map <C-m> feedkeys ":bmark"
map <C-=> zoom in
map <C--> zoom out

